# AI Employee Vault - Git Ignore

# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
Logs/*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp

# Session files (WhatsApp, etc.)
*.session
*.session.json
session_data/

# Approval files (may contain sensitive info)
Pending_Approval/*
Approved/*
Rejected/*

# Action files with potential sensitive data
Needs_Action/*
Done/*

# Keep the folder structure but ignore contents
!Needs_Action/.gitkeep
!Done/.gitkeep
!Pending_Approval/.gitkeep
!Approved/.gitkeep
!Rejected/.gitkeep
!Plans/.gitkeep
!Inbox/.gitkeep
!Accounting/.gitkeep
!Briefings/.gitkeep
!Invoices/.gitkeep
!Logs/.gitkeep
