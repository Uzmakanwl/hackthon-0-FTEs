# Environment Variables for AI Employee
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===========================================
# Gmail API (For Gmail Watcher - Silver Tier)
# ===========================================
# Get credentials from: https://console.cloud.google.com/
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here
GMAIL_API_KEY=your_api_key_here

# ===========================================
# WhatsApp Session (For WhatsApp Watcher)
# ===========================================
# Local path to store WhatsApp Web session
WHATSAPP_SESSION_PATH=/path/to/whatsapp/session

# ===========================================
# Bank API (For Finance Watcher - Silver Tier)
# ===========================================
# Your bank's API credentials
BANK_API_TOKEN=your_bank_token_here
BANK_API_KEY=your_bank_key_here

# ===========================================
# Claude Code / Anthropic API
# ===========================================
# If using API directly (optional - Claude Code CLI handles auth)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ===========================================
# MCP Server Configuration
# ===========================================
# Email MCP
EMAIL_MCP_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ===========================================
# Development Settings
# ===========================================
# Enable dry-run mode (no real actions taken)
DRY_RUN=true

# Maximum actions per hour (rate limiting)
MAX_ACTIONS_PER_HOUR=10

# ===========================================
# Vault Paths
# ===========================================
# Absolute path to your Obsidian vault
VAULT_PATH=C:/Users/YOUR_USERNAME/Desktop/hackthon-0-FTEs/AI_Employee_Vault

# Drop folder to monitor
DROP_FOLDER_PATH=C:/Users/YOUR_USERNAME/Desktop/hackthon-0-FTEs/AI_Employee_Vault/DropFolder
